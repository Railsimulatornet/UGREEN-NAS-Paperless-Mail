# paperlessngx.env (KEY=VALUE)
# ============================================================
# Community package: Paperless-ngx + Export Script (UGREEN NAS)
# Author: Roman Glos (Community)
#
# ✅ This file is used by docker-compose AND the scripts.
#    (You can optionally split it later into:
#     - paperlessngx.env (Docker)
#     - scripts.env (Scripts/SMTP) )
#
# IMPORTANT:
# - For values containing special characters, it is best to use quotes:  PASS="abc!?_%"
# - Protect the file: chmod 600 paperlessngx.env
# ============================================================

# -------------------------
# UID / GID (your values)
# -------------------------
USERMAP_UID=1009
USERMAP_GID=10

# -------------------------
# Paperless Admin User
# (created on first start; afterwards you can comment it out)
# -------------------------
PAPERLESS_ADMIN_USER=paperlessadmin
PAPERLESS_ADMIN_PASSWORD="CHANGE_ME_ADMIN_PASSWORD"

# -------------------------
# Paperless Secret Key (set once, then NEVER change it!)
# Tip: openssl rand -base64 48
# -------------------------
PAPERLESS_SECRET_KEY="CHANGE_ME_LONG_RANDOM_SECRET_KEY"

# -------------------------
# Paperless Basics
# -------------------------
PAPERLESS_TIME_ZONE=Europe/Berlin
PAPERLESS_OCR_LANGUAGE=deu+eng

# -------------------------
# Redis
# -------------------------
PAPERLESS_REDIS=redis://broker:6379

# -------------------------
# PostgreSQL 18
# -------------------------
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD="CHANGE_ME_DB_PASSWORD"
# PG18+: data directory inside the volume
PGDATA=/var/lib/postgresql/18/docker

# Paperless DB connection
PAPERLESS_DBHOST=db
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS="CHANGE_ME_DB_PASSWORD"

# -------------------------
# Paperless Optional Settings
# -------------------------
PAPERLESS_FILENAME_FORMAT={{ created_year }}/{{ created }}-{{ correspondent }}-{{ document_type }}-{{ title }}
PAPERLESS_FILENAME_FORMAT_REMOVE_NONE=true
PAPERLESS_FILENAME_DATE_ORDER=YMD
PAPERLESS_CONSUMER_DELETE_DUPLICATES=true
PAPERLESS_CONSUMER_RECURSIVE=true
PAPERLESS_IGNORE_DATES=1970-01-01
PAPERLESS_OCR_USER_ARGS={"invalidate_digital_signatures":true}

# ============================================================
# SMTP / Mail (for the export script)
# ============================================================
MAIL_ENABLED=1
MAIL_ON_SUCCESS=0
MAIL_ON_FAILURE=1
# 1 = use [OK]/[FAIL] instead of ✅/❌ (if your mail server breaks UTF-8)
MAIL_ASCII_ICONS=0


# 1 = send email as multipart (Text + HTML). 0 = text only.
MAIL_SEND_HTML=1

# File list in email (HTML + Text) – good for mobile/Outlook
MAIL_FILELIST_ENABLED=1
# How many files should be shown?
MAIL_FILELIST_LIMIT=10

# Exported files (contents of the ZIP export)
# 1 = show the list of exported files in the email
MAIL_EXPORTED_FILES_ENABLED=0
# Mode: grouped = show all variants per document (original/archive/thumbnail)
#        primary = show only the primary file (e.g. PDF only)
MAIL_EXPORTED_FILES_MODE=primary
# Which extensions count as the primary file? (comma-separated, no dot)
MAIL_EXPORTED_FILES_PRIMARY_EXTS=pdf
# How many items/documents should be shown? (0 = disabled)
MAIL_EXPORTED_FILES_LIMIT=50
SMTP_HOST=smtp.example.com
TLS_ENABLED=1
# Leave SMTP_PORT empty = auto (TLS->587, without TLS->25). For SMTPS: 465
SMTP_PORT=
SMTP_USER=user@example.com
SMTP_PASS="CHANGE_ME_SMTP_PASSWORD"

MAIL_FROM=user@example.com
MAIL_FROM_NAME="UGREEN Paperless Export"
# Multiple recipients possible: a@b.de,b@c.de
MAIL_TO=ziel@example.com

# ============================================================
# Script: Paperless Export (document_exporter)
# ============================================================
PAPERLESS_CONTAINER_NAME=Paperless-ngx
# Host destination directory for ZIP backups (must exist / be creatable)
PAPERLESS_HOST_BACKUP_DIR=/volume2/docker/paperless-ngx/export
PAPERLESS_KEEP_FILES=10
# Temporary directory inside the container
PAPERLESS_CONTAINER_TMP_DIR=/usr/src/paperless/export/_tmp
# Optional: logfile (host path). If empty, the script uses ./scripts/exporter.log
PAPERLESS_EXPORT_LOGFILE=/volume2/docker/paperless-ngx/scripts/exporter.log
# Note: If you really want to use /tmp, set e.g. PAPERLESS_CONTAINER_TMP_DIR=/tmp/paperless-export.
# The script will then try chmod 777 inside the container automatically (via docker exec -u 0).
